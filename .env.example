# =============================================================================
# OpenClaw Teams - Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Runtime environment: development | staging | production
NODE_ENV=development

# HTTP server port
PORT=3000

# Log verbosity: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# Full connection string (takes precedence over individual vars if set)
DATABASE_URL=postgresql://openclaw:changeme@localhost:5432/openclaw_teams

# Individual connection parameters (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openclaw_teams
DB_USER=openclaw
DB_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Full connection string (takes precedence over individual vars if set)
REDIS_URL=redis://:changeme@localhost:6379/0

# Individual connection parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Anthropic (Claude AI)
# This project uses Claude exclusively — do NOT add an OpenAI key here.
# -----------------------------------------------------------------------------
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
# Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret used to verify incoming Slack requests
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Incoming webhook URL for posting notifications to a channel
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR_TEAM/YOUR_CHANNEL/YOUR_TOKEN

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
# Personal access token or GitHub App installation token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to verify incoming webhook payloads from GitHub
GITHUB_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# SMTP / Email
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
# Admin password for the bundled Grafana instance
GRAFANA_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used to sign and verify JWT tokens — use a long random string
JWT_SECRET=change-me-to-a-very-long-random-secret-string-at-least-64-characters

# -----------------------------------------------------------------------------
# AWS / Backup
# -----------------------------------------------------------------------------
# S3 bucket name for automated backups
BACKUP_BUCKET=openclaw-teams-backups

# AWS region where the backup bucket lives
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
# DSN from https://sentry.io/ — leave blank to disable Sentry
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
