# =============================================================================
# OpenClaw Teams — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
secrets/
docker/secrets/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Compiled output
# -----------------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Test coverage & reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
junit.xml
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# Runtime & temp files
# -----------------------------------------------------------------------------
pids/
*.pid
*.pid.lock
*.seed
*.lock
tmp/
temp/
.tmp/
.serena/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/
nbproject/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Terraform / infrastructure state
# -----------------------------------------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
.terraformrc
terraform.rc

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/
.vercel/
.netlify/
*.tgz
*.zip
*.tar.gz

# Combined export file (too large for repo)
OPENCLAW_TEAMS_COMPLETE.txt

# Cowork session temp files
_tmp_*
cowork-skills/
